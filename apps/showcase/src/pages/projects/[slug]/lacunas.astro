---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ProjectSectionNav from "../../../components/ProjectSectionNav.astro";
import GapsPanel from "../../../components/GapsPanel.astro";
import MaturityBar from "../../../components/MaturityBar.astro";
import {
  loadIndex,
  loadPreview,
  loadAgentsView,
  formatPercent,
  dimensionLabel,
  journeyPhaseLabel,
} from "../../../lib/registry";
import { extractGaps } from "../../../lib/gaps";
import { withBase } from "../../../lib/paths";

export async function getStaticPaths() {
  const { projects } = loadIndex();
  return projects
    .filter((p) => p.public !== false)
    .map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const project = await loadPreview(slug!);
const agents = await loadAgentsView(slug!);

if (!project) {
  return Astro.redirect(withBase("/"));
}

const gaps = extractGaps(project);
const allGaps = project.gaps?.top ?? gaps.top;
const dimGaps = project.gaps?.dimension_gaps ?? project.dimension_gaps ?? {};
const journeyPhase = agents?.journey_phase;

const gapSuggestions = project.gaps?.gap_suggestions ?? [];
function suggestionsFor(dimension: string, gap: string): string[] {
  return (
    gapSuggestions.find((s) => s.dimension === dimension && s.gap === gap)?.answers ?? []
  );
}
---

<BaseLayout
  title={`Lacunas — ${project.title}`}
  description={`${gaps.total_count} lacunas pendentes — continue o intake no Cursor.`}
>
  <header class="site-header site-header-compact project-hero-compact">
    <div class="container">
      <a class="back-link" href={withBase(`/projects/${slug}/`)}>← Visão do projeto</a>
      <div class="meta-row">
        <span class="badge chip-gap-count">Lacunas ({gaps.total_count})</span>
        {journeyPhase && (
          <span class="badge project-phase-badge">{journeyPhaseLabel(journeyPhase)}</span>
        )}
      </div>
      <h1>O que falta preencher</h1>
      <p class="hero-lead">
        Lacunas são decisões ainda não tomadas — maturidade, sugestões de mercado ou confirmações pendentes.
        No site público você copia o prompt para o Cursor; rodando localmente, decide aqui mesmo.
      </p>
      {project.readiness != null && (
        <div style="margin-top: 1rem; max-width: 28rem;">
          <MaturityBar value={project.readiness} label="Maturidade geral" variant="hero" />
        </div>
      )}
    </div>
  </header>

  <div class="container">
    <ProjectSectionNav slug={slug!} hasProcess={agents != null} activeSection="lacunas" gapCount={gaps.total_count} />
  </div>

  <main id="main-content" class="container project-sections">
    <div
      id="gap-decisions-config"
      data-slug={slug}
      data-base={import.meta.env.BASE_URL}
      hidden
    >
    </div>
    <p class="panel gap-local-banner" data-gap-interactive hidden>
      <strong>Modo interativo local ativo.</strong>
      Decisões tomadas aqui são gravadas em <code>.sky/sessions/{slug}/</code> e auditadas — nada muda sem você.
    </p>

    <GapsPanel slug={slug!} gaps={gaps} variant="page" />

    {Object.keys(dimGaps).length > 0 && (
      <section class="panel project-section">
        <h2 class="section-title">Por dimensão</h2>
        <p class="panel-hint" data-gap-interactive hidden>
          Responda uma lacuna aqui — a resposta vai para a caixa de decisões da sessão e o intake continua de onde você parou.
        </p>
        {Object.entries(dimGaps).map(([dim, list]) => (
          <div class="gaps-dimension-block">
            <h3>
              {dimensionLabel(dim)}
              {project.dimensions?.[dim] != null && (
                <span class="chip chip-gap-dim">{formatPercent(project.dimensions[dim])}</span>
              )}
            </h3>
            <ul class="plain-list gaps-dimension-list">
              {list.map((g, i) => (
                <li class="gaps-dimension-item">
                  <span>{g}</span>
                  <form
                    class="gap-answer-form"
                    data-gap-answer
                    data-gap-interactive
                    data-item-id={`dim-${dim}-${i + 1}`}
                    data-item-label={g}
                    data-dimension={dim}
                    hidden
                  >
                    {suggestionsFor(dim, g).length > 0 && (
                      <fieldset class="gap-suggestions">
                        <legend class="gap-suggestions-label">
                          Sugestões da IA — toque para preencher, edite à vontade
                        </legend>
                        {suggestionsFor(dim, g).map((answer) => (
                          <button
                            type="button"
                            class="gap-suggestion-chip"
                            data-suggestion
                            aria-pressed="false"
                          >
                            {answer}
                          </button>
                        ))}
                      </fieldset>
                    )}
                    <label class="gap-answer-label" for={`answer-${dim}-${i + 1}`}>
                      Sua resposta
                    </label>
                    <textarea
                      id={`answer-${dim}-${i + 1}`}
                      class="gap-answer-textarea"
                      rows="3"
                      placeholder="Escreva a decisão ou a informação que falta…"
                    ></textarea>
                    <button type="submit" class="btn-secondary gap-answer-submit">Responder</button>
                  </form>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </section>
    )}

    {(project.gaps?.ai_suggested_rfs?.length ?? 0) > 0 && (
      <section class="panel project-section">
        <h2 class="section-title">Requisitos sugeridos (benchmark)</h2>
        <p class="panel-hint">
          Sugeridos pelo market-benchmark — confirme para incluir no escopo ou descarte explicitamente.
        </p>
        <ul class="requirement-cards">
          {project.gaps!.ai_suggested_rfs!.map((rf) => {
            const status = rf.status ?? "pending";
            return (
              <li class="requirement-card" data-rf-status={status}>
                <div class="requirement-card-head">
                  <span class="req-id">{rf.id}</span>
                  {status === "pending" && (
                    <span class="chip chip-gap-ai_suggested">Sugestão IA</span>
                  )}
                  {status === "accepted" && (
                    <span class="chip chip-gap-accepted">Aceito por você</span>
                  )}
                  {status === "rejected" && (
                    <span class="chip chip-gap-rejected">Recusado</span>
                  )}
                </div>
                <p class="requirement-card-title">{rf.title}</p>
                {rf.description && <p class="requirement-card-desc">{rf.description}</p>}
                {status === "pending" && (
                  <div
                    class="gap-actions"
                    data-gap-actions
                    data-gap-interactive
                    data-item-id={rf.id}
                    data-item-label={rf.title}
                    hidden
                  >
                    <button type="button" class="btn-primary gap-action-btn" data-decide="confirm">
                      Aceitar
                    </button>
                    <button type="button" class="btn-secondary gap-action-btn" data-decide="reject">
                      Recusar
                    </button>
                    <button type="button" class="btn-secondary gap-action-btn" data-decide="skip">
                      Decidir depois
                    </button>
                  </div>
                )}
              </li>
            );
          })}
        </ul>
      </section>
    )}

    {allGaps.length > gaps.top.length && (
      <section class="panel project-section">
        <h2 class="section-title">Lista completa</h2>
        <ul class="gaps-full-list">
          {allGaps.map((gap, i) => (
            <li class="gaps-full-item">
              <span class="gaps-rank">{i + 1}</span>
              <span>{gap.label}</span>
            </li>
          ))}
        </ul>
      </section>
    )}
  </main>

  <div id="gap-toast" class="gap-toast" role="status" aria-live="polite"></div>
</BaseLayout>

<script>
  import { initGapDecisions } from "../../../scripts/gap-decisions";

  initGapDecisions();
</script>
