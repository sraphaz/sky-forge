---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ProjectSectionNav from "../../../components/ProjectSectionNav.astro";
import GapsPanel from "../../../components/GapsPanel.astro";
import MaturityBar from "../../../components/MaturityBar.astro";
import {
  loadIndex,
  loadPreview,
  loadAgentsView,
  formatPercent,
  dimensionLabel,
  journeyPhaseLabel,
} from "../../../lib/registry";
import { extractGaps } from "../../../lib/gaps";
import { withBase } from "../../../lib/paths";

export async function getStaticPaths() {
  const { projects } = loadIndex();
  return projects
    .filter((p) => p.public !== false)
    .map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const project = await loadPreview(slug!);
const agents = await loadAgentsView(slug!);

if (!project) {
  return Astro.redirect(withBase("/hub/"));
}

const gaps = extractGaps(project);
const allGaps = project.gaps?.top ?? gaps.top;
const dimGaps = project.gaps?.dimension_gaps ?? project.dimension_gaps ?? {};
const journeyPhase = agents?.journey_phase;

const gapSuggestions = project.gaps?.gap_suggestions ?? [];
function gapMeta(dimension: string, gap: string) {
  return gapSuggestions.find((s) => s.dimension === dimension && s.gap === gap);
}
---

<BaseLayout
  title={`Lacunas — ${project.title}`}
  description={`${gaps.total_count} lacunas pendentes — continue o intake no Cursor.`}
>
  <header class="site-header site-header-compact project-hero-compact">
    <div class="container">
      <a class="back-link" href={withBase(`/projects/${slug}/`)}>← Visão do projeto</a>
      <div class="meta-row">
        <span class="badge chip-gap-count">Lacunas (<span data-gap-count>{gaps.total_count}</span>)</span>
        {journeyPhase && (
          <span class="badge project-phase-badge">{journeyPhaseLabel(journeyPhase)}</span>
        )}
      </div>
      <h1>O que falta preencher</h1>
      <p class="hero-lead">
        Lacunas são decisões ainda não tomadas — maturidade, sugestões de mercado ou confirmações pendentes.
        No site público você copia o prompt para o Cursor; rodando localmente, decide aqui mesmo.
      </p>
      {project.readiness != null && (
        <div style="margin-top: 1rem; max-width: 28rem;">
          <MaturityBar value={project.readiness} label="Maturidade geral" variant="hero" />
        </div>
      )}
    </div>
  </header>

  <div class="container">
    <ProjectSectionNav slug={slug!} hasProcess={agents != null} activeSection="lacunas" gapCount={gaps.total_count} />
  </div>

  <main id="main-content" class="container project-sections">
    <div
      id="gap-decisions-config"
      data-slug={slug}
      data-base={import.meta.env.BASE_URL}
      hidden
    >
    </div>
    <p class="panel gap-local-banner" data-gap-interactive hidden>
      <strong>Modo interativo local ativo.</strong>
      Decisões tomadas aqui são gravadas em <code>.sky/sessions/{slug}/</code> e auditadas — nada muda sem você.
      <button type="button" id="gap-project-refresh" class="btn-secondary gap-refresh-btn">
        Atualizar projeto
      </button>
    </p>
    <p class="panel gap-stale-api-banner" data-gap-stale-api hidden>
      <strong>API local desatualizada.</strong>
      Um servidor antigo ainda ocupa a porta — reinicie o showcase para habilitar envio em lote e atualização sem reload:
      <code>./scripts/sky/sky.ps1 showcase</code>
    </p>

    <GapsPanel slug={slug!} gaps={gaps} variant="page" />

    {Object.keys(dimGaps).length > 0 && (
      <section class="panel project-section">
        <h2 class="section-title">Por dimensão</h2>
        <p class="panel-hint" data-gap-interactive hidden>
          Marque várias lacunas, escolha sugestões da IA (ou escreva a sua) e envie tudo de uma vez — sem perder o restante da página.
        </p>
        {Object.entries(dimGaps).map(([dim, list]) => (
          <div class="gaps-dimension-block">
            <h3>
              {dimensionLabel(dim)}
              {project.dimensions?.[dim] != null && (
                <span class="chip chip-gap-dim">{formatPercent(project.dimensions[dim])}</span>
              )}
            </h3>
            <ul class="plain-list gaps-dimension-list">
              {list.map((g, i) => {
                const meta = gapMeta(dim, g);
                const itemId = `dim-${dim}-${i + 1}`;
                return (
                  <li
                    class="gaps-dimension-item"
                    data-gap-item-id={itemId}
                    data-gap-status="pending"
                  >
                    <div class="gap-item-header">
                      <label class="gap-batch-check" data-gap-interactive hidden>
                        <input type="checkbox" class="gap-batch-select" data-batch-select aria-label={`Incluir lacuna: ${g}`} />
                        <span class="gap-item-label">{g}</span>
                      </label>
                      <span class="gap-item-label-static" data-gap-static>{g}</span>
                    </div>
                    {meta?.gap_effect && (
                      <p class="gap-item-effect" data-gap-interactive hidden>{meta.gap_effect}</p>
                    )}
                    <form
                      class="gap-answer-form"
                      data-gap-answer
                      data-gap-interactive
                      data-item-id={itemId}
                      data-item-label={g}
                      data-dimension={dim}
                      hidden
                    >
                      {(meta?.items?.length ?? 0) > 0 && (
                        <fieldset class="gap-suggestions">
                          <legend class="gap-suggestions-label">
                            Sugestões da IA — toque para preencher, edite à vontade
                          </legend>
                          {meta!.items.map((item) => (
                            <div class="gap-suggestion-card">
                              {item.recommended && (
                                <span class="chip chip-recommended">Recomendada</span>
                              )}
                              <button
                                type="button"
                                class="gap-suggestion-chip"
                                data-suggestion
                                data-suggestion-text={item.text}
                                aria-pressed="false"
                              >
                                {item.text}
                              </button>
                              {item.effect && (
                                <p class="gap-suggestion-effect">{item.effect}</p>
                              )}
                            </div>
                          ))}
                        </fieldset>
                      )}
                      <label class="gap-answer-label" for={`answer-${dim}-${i + 1}`}>
                        Sua resposta
                      </label>
                      <textarea
                        id={`answer-${dim}-${i + 1}`}
                        class="gap-answer-textarea"
                        rows="3"
                        placeholder="Escreva a decisão ou a informação que falta…"
                      ></textarea>
                      <div class="gap-answer-actions">
                        <button type="button" class="btn-secondary gap-answer-submit" data-send-single>
                          Responder agora
                        </button>
                      </div>
                    </form>
                  </li>
                );
              })}
            </ul>
          </div>
        ))}
      </section>
    )}

    {(project.gaps?.ai_suggested_rfs?.length ?? 0) > 0 && (
      <section class="panel project-section">
        <h2 class="section-title">Requisitos sugeridos (benchmark)</h2>
        <p class="panel-hint">
          Sugeridos pelo market-benchmark — confirme para incluir no escopo ou descarte explicitamente.
        </p>
        <ul class="requirement-cards">
          {project.gaps!.ai_suggested_rfs!.map((rf) => {
            const status = rf.status ?? "pending";
            return (
              <li
                class="requirement-card"
                data-rf-status={status}
                data-gap-item-id={rf.id}
                data-gap-status={status}
              >
                <div class="requirement-card-head">
                  <label class="gap-batch-check gap-batch-check-rf" data-gap-interactive hidden>
                    <input
                      type="checkbox"
                      class="gap-batch-select"
                      data-batch-select
                      aria-label={`Incluir ${rf.id} no envio em lote`}
                      disabled={status !== "pending"}
                    />
                  </label>
                  <span class="req-id">{rf.id}</span>
                  {status === "pending" && (
                    <span class="chip chip-gap-ai_suggested">Sugestão IA</span>
                  )}
                  {status === "accepted" && (
                    <span class="chip chip-gap-accepted">Aceito por você</span>
                  )}
                  {status === "rejected" && (
                    <span class="chip chip-gap-rejected">Recusado</span>
                  )}
                </div>
                <p class="requirement-card-title">{rf.title}</p>
                {rf.description && <p class="requirement-card-desc">{rf.description}</p>}
                {rf.effect && <p class="gap-item-effect gap-rf-effect">{rf.effect}</p>}
                {status === "pending" && (
                  <div
                    class="gap-actions"
                    data-gap-actions
                    data-gap-interactive
                    data-item-id={rf.id}
                    data-item-label={rf.title}
                    hidden
                  >
                    <div class="gap-rf-batch-options" role="radiogroup" aria-label={`Decisão para ${rf.id}`}>
                      <label class="gap-rf-radio">
                        <input type="radio" name={`rf-batch-${rf.id}`} data-rf-batch value="confirm" />
                        Aceitar (lote)
                      </label>
                      <label class="gap-rf-radio">
                        <input type="radio" name={`rf-batch-${rf.id}`} data-rf-batch value="reject" />
                        Recusar (lote)
                      </label>
                      <label class="gap-rf-radio">
                        <input type="radio" name={`rf-batch-${rf.id}`} data-rf-batch value="skip" />
                        Depois (lote)
                      </label>
                    </div>
                    <div class="gap-rf-immediate">
                      <button type="button" class="btn-primary gap-action-btn" data-decide="confirm">
                        Aceitar
                      </button>
                      <button type="button" class="btn-secondary gap-action-btn" data-decide="reject">
                        Recusar
                      </button>
                      <button type="button" class="btn-secondary gap-action-btn" data-decide="skip">
                        Decidir depois
                      </button>
                    </div>
                  </div>
                )}
              </li>
            );
          })}
        </ul>
      </section>
    )}

    {allGaps.length > gaps.top.length && (
      <section class="panel project-section">
        <h2 class="section-title">Lista completa</h2>
        <ul class="gaps-full-list">
          {allGaps.map((gap, i) => (
            <li class="gaps-full-item">
              <span class="gaps-rank">{i + 1}</span>
              <span>{gap.label}</span>
            </li>
          ))}
        </ul>
      </section>
    )}
  </main>

  <div id="gap-batch-bar" class="gap-batch-bar" hidden aria-live="polite">
    <span id="gap-batch-count">0 seleções</span>
    <button type="button" id="gap-batch-submit" class="btn-primary">Enviar seleções</button>
    <button type="button" id="gap-batch-clear" class="btn-secondary">Limpar</button>
  </div>

  <div id="gap-toast" class="gap-toast" role="status" aria-live="polite"></div>
</BaseLayout>

<script>
  import { initGapDecisions } from "../../../scripts/gap-decisions";

  initGapDecisions();
</script>
