---
import BaseLayout from "../layouts/BaseLayout.astro";
import HubHeader from "../components/HubHeader.astro";
import ProjectCard from "../components/ProjectCard.astro";
import GapsPanel from "../components/GapsPanel.astro";
import { loadIndex, loadPreview } from "../lib/registry";
import { extractGaps, gapCountForIndex } from "../lib/gaps";
import { withBase } from "../lib/paths";

const { projects } = loadIndex();
const visible = projects.filter((p) => p.public !== false);
const featured = visible[0];
const rest = visible.slice(1);

const featuredPreview = featured ? await loadPreview(featured.slug) : null;
const featuredGaps = featuredPreview ? extractGaps(featuredPreview) : null;

const projectsWithGaps = await Promise.all(
  visible.map(async (p) => {
    const preview = await loadPreview(p.slug);
    const count = preview ? gapCountForIndex(preview) : p.gap_count ?? 0;
    return { ...p, gap_count: count };
  }),
);
const featuredWithGaps = projectsWithGaps[0];
const restWithGaps = projectsWithGaps.slice(1);
---

<BaseLayout
  title="Hub de projetos"
  description="Galeria de propostas elevadas pelo Sky-Forge — resumos sanitizados, índices SKY e maturidade."
  navActive="projetos"
>
  <HubHeader
    kicker="GALERIA DE PROPOSTAS ELEVADAS"
    title="O que falta — e o que já elevamos."
    subtitle="Lacunas aparecem primeiro. Cada projeto publicado passou pelo funil com consentimento; o intake continua no Cursor."
  />

  <main id="main-content" class="container sf-page">
    {visible.length === 0 ? (
      <div class="empty-state panel sf-panel" role="status">
        <p class="sf-kicker">SEM PROJETOS PUBLICADOS</p>
        <p><strong>Comece pela intenção.</strong></p>
        <p class="panel-hint">Uma conversa em linguagem natural é suficiente. O funil organiza brief, UX, arquitetura e elevação — privacidade por padrão até você optar por publicar.</p>
        <ol class="flow-list">
          <li>Intake local: <code class="sf-code-inline">./scripts/sky/sky.ps1 intake -Slug meu-projeto</code></li>
          <li>Export quando estiver pronto (pasta externa)</li>
          <li>Publish só com opt-in: <code class="sf-code-inline">-Public</code></li>
        </ol>
        <p><a href={withBase("/sobre/")} class="btn-primary">Como a plataforma funciona →</a></p>
      </div>
    ) : (
      <>
        {featuredGaps && featuredGaps.total_count > 0 && featured && (
          <div class="hub-gaps-first">
            <GapsPanel slug={featured.slug} gaps={featuredGaps} variant="hero" />
          </div>
        )}

        <div class="showcase-gallery">
          {featuredWithGaps && <ProjectCard project={featuredWithGaps} featured gapCount={featuredWithGaps.gap_count} />}
          <aside class="showcase-next-slot sf-panel">
            <p class="sf-kicker">NOVO PROJETO</p>
            <h3 class="showcase-next-title">Descreva a ideia — lacunas virão primeiro.</h3>
            <p class="panel-hint">Intake local, privacidade por padrão. O showcase só mostra o que você publicar.</p>
            <code class="cta-code">./scripts/sky/sky.ps1 intake -Slug meu-projeto</code>
            <a href={withBase("/sobre/#instalacao-local")} class="btn-primary" style="margin-top: 0.75rem;">Entrar no funil →</a>
          </aside>
        </div>
        {restWithGaps.length > 0 && (
          <div class="grid sf-grid-secondary">
            {restWithGaps.map((project) => (
              <ProjectCard project={project} gapCount={project.gap_count} />
            ))}
          </div>
        )}
      </>
    )}
  </main>
</BaseLayout>
