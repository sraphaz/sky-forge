---
import { withBase } from "../lib/paths";

interface Props {
  slug: string;
  hasProduction?: boolean;
  hasProcess?: boolean;
  hasMarket?: boolean;
  activeSection?: "overview" | "artefatos" | "agentes" | "lacunas";
  gapCount?: number;
}

const {
  slug,
  hasProduction = true,
  hasProcess = true,
  hasMarket = false,
  activeSection = "overview",
  gapCount = 0,
} = Astro.props;

const lacunasHref = withBase(`/projects/${slug}/lacunas/`);

const anchorSections = [
  ...(gapCount > 0 ? [{ id: "lacunas", label: "Lacunas" }] : []),
  { id: "indices", label: "Índices" },
  ...(hasMarket ? [{ id: "mercado", label: "Mercado" }] : []),
  { id: "visao", label: "Visão" },
  { id: "funcionalidades", label: "Funcionalidades" },
  { id: "requisitos", label: "Requisitos" },
  { id: "arquitetura", label: "Arquitetura" },
  { id: "producao", label: "Roadmap" },
  ...(hasProcess ? [{ id: "como-foi-produzido", label: "Produção" }] : []),
];
---

<nav class="section-nav" aria-label="Seções do projeto">
  <a
    href={lacunasHref}
    class:list={[
      "section-nav-link",
      "section-nav-lacunas",
      activeSection === "lacunas" && "section-nav-active",
    ]}
  >
    Lacunas{gapCount > 0 ? " (" : ""}{gapCount > 0 && <span data-gap-count>{gapCount}</span>}{gapCount > 0 ? ")" : ""}
  </a>
  {activeSection === "overview" ? (
    anchorSections.map((s) => (
      <a href={`#${s.id}`} class="section-nav-link">{s.label}</a>
    ))
  ) : activeSection !== "lacunas" ? (
    <a href={withBase(`/projects/${slug}/`)} class="section-nav-link">Visão geral</a>
  ) : null}
  <a
    href={withBase(`/projects/${slug}/artefatos/`)}
    class={`section-nav-link ${activeSection === "artefatos" ? "section-nav-active" : ""}`}
  >
    Artefatos
  </a>
  {hasProcess && (
    <a
      href={withBase(`/projects/${slug}/agentes/`)}
      class={`section-nav-link section-nav-meta ${activeSection === "agentes" ? "section-nav-active" : ""}`}
    >
      Trilha de agentes →
    </a>
  )}
</nav>
