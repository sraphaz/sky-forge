---
import { autonomyLabel, gateLabel, outcomeClass, formatTime } from "../lib/registry";
import type { AgentsView } from "../lib/registry";
import { withBase } from "../lib/paths";

interface Props {
  agents: AgentsView;
  projectTitle: string;
  slug: string;
}

const { agents, projectTitle, slug } = Astro.props;
const choreo = agents.choreography;
const counts = agents.event_counts ?? { ok: 0, blocked: 0, other: 0 };
---

<nav class="tab-nav">
  <a href={withBase(`/projects/${slug}/`)} class="tab">Visão do aplicativo</a>
  <a href={withBase(`/projects/${slug}/agentes/`)} class="tab tab-active">Como foi produzido</a>
</nav>

<div class="hero-stats" style="margin-bottom: 1.5rem;">
  <div class="stat">
    <div class="stat-value" style="color: var(--color-sky-mid); font-size: 1.75rem;">{agents.metrics?.total_events ?? 0}</div>
    <div class="stat-label" style="color: var(--color-text-muted);">Eventos auditados</div>
  </div>
  <div class="stat">
    <div class="stat-value" style="color: var(--color-success); font-size: 1.75rem;">{counts.ok}</div>
    <div class="stat-label" style="color: var(--color-text-muted);">OK</div>
  </div>
  <div class="stat">
    <div class="stat-value" style="color: var(--color-danger); font-size: 1.75rem;">{counts.blocked}</div>
    <div class="stat-label" style="color: var(--color-text-muted);">Bloqueados</div>
  </div>
  {agents.journey_phase && (
    <div class="stat">
      <div class="stat-value" style="font-size: 1.1rem; text-transform: capitalize; color: var(--color-sky-mid);">{agents.journey_phase}</div>
      <div class="stat-label" style="color: var(--color-text-muted);">Fase UX</div>
    </div>
  )}
</div>

<div class="two-col">
  <section class="panel">
    <h3>Gates humanos</h3>
    <p class="panel-hint">Aprovações necessárias antes de export público ou side effects.</p>
    {agents.gates && agents.gates.length > 0 ? (
      <ul class="gate-list">
        {agents.gates.map((gate) => (
          <li class={`gate-item ${gate.approved ? "gate-approved" : "gate-pending"}`}>
            <span class="gate-icon">{gate.approved ? "✓" : "○"}</span>
            <span>{gateLabel(gate.id)}</span>
            <span class="chip">{gate.approved ? "aprovado" : "pendente"}</span>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty">Sem gates configurados.</p>
    )}
  </section>

  <section class="panel">
    <h3>Coreografia ativa</h3>
    {choreo?.matched_rules && choreo.matched_rules.length > 0 && (
      <p class="panel-hint">Regras: {choreo.matched_rules.join(", ")}</p>
    )}
    {choreo?.operational && choreo.operational.length > 0 ? (
      <ul class="agent-roster">
        {choreo.operational.map((agent) => (
          <li class="agent-card">
            <div class="agent-card-header">
              <strong>{agent.id}</strong>
              <span class="chip chip-autonomy">{autonomyLabel(agent.max_autonomy ?? "observe")}</span>
            </div>
            {agent.skills && agent.skills.length > 0 && (
              <div class="meta-row">
                {agent.skills.map((sk) => <span class="chip chip-skill">{sk}</span>)}
              </div>
            )}
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty">Nenhum agente operacional resolvido.</p>
    )}
    {choreo?.domain_consults && choreo.domain_consults.length > 0 && (
      <>
        <h4 class="subheading">Consulta de domínio</h4>
        <div class="meta-row">
          {choreo.domain_consults.map((d) => <span class="chip">{d}</span>)}
        </div>
      </>
    )}
  </section>
</div>

<section class="panel">
  <h3>Trilha de auditoria</h3>
  <p class="panel-hint">Últimos eventos de agentes em <strong>{projectTitle}</strong> (sanitizados).</p>
  {agents.events && agents.events.length > 0 ? (
    <div class="audit-table-wrap">
      <table class="audit-table">
        <thead>
          <tr>
            <th>Quando</th>
            <th>Agente</th>
            <th>Ação</th>
            <th>Autonomia</th>
            <th>Resultado</th>
          </tr>
        </thead>
        <tbody>
          {agents.events.slice().reverse().map((ev) => (
            <tr>
              <td class="audit-ts">{formatTime(ev.ts)}</td>
              <td><code>{ev.agent_id}</code></td>
              <td>{ev.action.replace(/\./g, " ")}</td>
              <td><span class="chip chip-autonomy">{autonomyLabel(ev.autonomy_level ?? "")}</span></td>
              <td>
                <span class={`outcome-pill ${outcomeClass(ev.outcome)}`}>{ev.outcome}</span>
                {ev.human_gate && <span class="chip" style="margin-left: 0.35rem;">gate: {ev.human_gate}</span>}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  ) : (
    <p class="empty">Nenhum evento publicado. Rode <code>sky publish</code> após atividade dos agentes.</p>
  )}
</section>

<section class="panel">
  <h3>Níveis de autonomia</h3>
  <div class="autonomy-ladder">
    {agents.autonomy_levels?.map((level) => (
      <div class="autonomy-step">
        <span class="autonomy-rank">{level.rank}</span>
        <span class="autonomy-name">{level.label}</span>
        <code class="autonomy-id">{level.id}</code>
      </div>
    ))}
  </div>
</section>
