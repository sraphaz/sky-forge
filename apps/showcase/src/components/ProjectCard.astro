---
import type { ProjectIndexEntry } from "../lib/registry";
import PendingBell from "./PendingBell.astro";
import { withBase } from "../lib/paths";

interface Props {
  project: ProjectIndexEntry;
  gapCount?: number;
}

const { project, gapCount = project.gap_count ?? 0 } = Astro.props;
const href = withBase(`/projects/${project.slug}/`);
const isPrivate = project.public === false;
---

<article class="card hub-project-card">
  <div class="hub-project-card-top">
    {isPrivate && <span class="chip chip-private">Privado</span>}
    <PendingBell slug={project.slug} count={gapCount} />
  </div>
  <h2 class="hub-project-title">
    <a href={href}>{project.title}</a>
  </h2>
  {project.excerpt && <p class="hub-project-excerpt">{project.excerpt}</p>}
  {project.tags && project.tags.length > 0 && (
    <div class="meta-row hub-project-tags">
      {project.tags.slice(0, 3).map((tag) => (
        <span class="chip chip-tag">{tag}</span>
      ))}
    </div>
  )}
  <a href={href} class="hub-project-link">Abrir projeto →</a>
</article>

<style>
  .hub-project-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .hub-project-card-top {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    min-height: 1.5rem;
  }

  .hub-project-title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    margin: 0;
    line-height: 1.35;
  }

  .hub-project-title a {
    color: inherit;
    text-decoration: none;
  }

  .hub-project-title a:hover {
    color: var(--color-sky-accent);
  }

  .hub-project-excerpt {
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--color-text-muted);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .hub-project-tags {
    margin: 0.25rem 0 0;
  }

  .hub-project-link {
    margin-top: 0.5rem;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-sky-accent);
    text-decoration: none;
  }

  .hub-project-link:hover {
    text-decoration: underline;
  }
</style>
