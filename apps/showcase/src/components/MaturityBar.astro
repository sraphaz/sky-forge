---
import { formatPercent } from "../lib/registry";

interface Props {
  value: number;
  label?: string;
  variant?: "default" | "hero" | "card";
  id?: string;
}

const { value, label = "Maturidade", variant = "default", id } = Astro.props;
const pct = Math.round(Math.min(1, Math.max(0, value)) * 100);
---

<div class:list={["maturity-bar", `maturity-bar-${variant}`]} role="group" aria-labelledby={id}>
  <div class="maturity-bar-header">
    <span class="maturity-bar-label" id={id}>{label}</span>
    <span class="maturity-bar-value">{formatPercent(value)}</span>
  </div>
  <div
    class="maturity-bar-track"
    role="progressbar"
    aria-valuenow={pct}
    aria-valuemin={0}
    aria-valuemax={100}
    aria-label={`${label}: ${pct}%`}
  >
    <div class="maturity-bar-fill" style={`width: ${pct}%`} />
  </div>
</div>
