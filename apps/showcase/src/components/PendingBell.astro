---
import { withBase } from "../lib/paths";

interface Props {
  slug: string;
  count: number;
}

const { slug, count } = Astro.props;
if (count <= 0) return null;

const href = withBase(`/projects/${slug}/#lacunas`);
---

<a
  href={href}
  class="pending-bell"
  aria-label={`${count} pendência${count !== 1 ? "s" : ""} — ver lacunas`}
  title={`${count} pendência${count !== 1 ? "s" : ""}`}
>
  <svg class="pending-bell-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path
      d="M12 2a5 5 0 0 0-5 5v2.1c0 .5-.2 1-.5 1.4L5.1 13.4A1 1 0 0 0 6 15h12a1 1 0 0 0 .9-1.6l-1.4-2.9c-.3-.4-.5-.9-.5-1.4V7a5 5 0 0 0-5-5Z"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linejoin="round"
    />
    <path d="M10 18a2 2 0 0 0 4 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
  </svg>
  <span class="pending-bell-count">{count}</span>
</a>
