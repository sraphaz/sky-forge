---
import "../styles/global.css";
import SiteFooter from "../components/SiteFooter.astro";
import PlatformNav from "../components/PlatformNav.astro";

interface Props {
  title: string;
  description?: string;
  navActive?: import("../components/PlatformNav.astro").HubNavId;
}

const {
  title,
  description = "Eleve o que está sendo proposto — especificação, UX digna e índices SKY.",
  navActive,
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#060913" />
    <title>{title} · Sky-Forge</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=Manrope:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        try {
          if (localStorage.getItem("sf-theme") === "light") {
            document.documentElement.setAttribute("data-theme", "light");
          }
        } catch (_) {}
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Ir para o conteúdo</a>
    <PlatformNav active={navActive} />
    <slot />
    <SiteFooter />
  </body>
</html>
